# Copy this file to .env for local runs (docker-compose reads .env automatically),
# or set these as environment variables on your host (Render, etc.). Never commit
# a real .env file.

# --- AI generation -----------------------------------------------------
# stub | ollama | openai | gemini | openai_compatible
AI_PROVIDER=stub
# Only used by AI_PROVIDER=openai. Base URL and model are hardcoded (api.openai.com).
OPENAI_API_KEY=
# Only used by AI_PROVIDER=gemini. Base URL and model are hardcoded (Gemini's
# OpenAI-compatible endpoint).
GEMINI_API_KEY=
# Only used by AI_PROVIDER=ollama / openai_compatible: base URL of that upstream
# server. e.g. http://localhost:11434 (Ollama) or https://api.your-provider.com/v1
AI_UPSTREAM_URL=https://js-stack-gaming.onrender.com
# Only used in openai_compatible mode, sent as "Authorization: Bearer <key>" upstream.
AI_UPSTREAM_API_KEY=
# Model name passed to the upstream provider (ollama/openai_compatible only —
# openai/gemini default to gpt-4o-mini / gemini-2.0-flash unless overridden here).
AI_MODEL=llama3.2

# --- Access control for THIS server's /api/v1/generate and /api/v1/profile ---
# If empty, both endpoints are open to anyone who finds the URL. Set this before
# deploying publicly, especially with a paid AI_UPSTREAM_URL.
AI_API_KEY=
# Comma-separated list of allowed browser origins, e.g. https://my-app.vercel.app
# Defaults to "*" (any site) if left empty — fine for local dev, not for production.
AI_ALLOWED_ORIGINS=

# --- Cross-device profile sync (/api/v1/profile/{account}) -------------
# Free Redis database from https://upstash.com — REST URL + token, no server to run.
# Leave both empty to disable sync entirely (routes return 503).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Question bank (/api/v1/questions + /api/v1/admin/questions) -------
# Postgres connection string from https://neon.tech (free tier). The schema is
# created automatically at first connection. Empty = bank disabled (503).
# Also hosts accounts, passes, payments and AI usage (see below).
DATABASE_URL=
# Secret gating the admin routes (create/edit/disable questions, paygate
# config, pricing). MUST be different from AI_API_KEY: the public key must
# never grant write access.
ADMIN_API_KEY=

# --- Player accounts (/api/v1/auth/*, /api/v1/me/*) --------------------
# Secret signing the player JWTs. Empty = accounts disabled (503 on auth
# routes; /generate falls back to the shared AI_API_KEY behaviour).
AUTH_JWT_SECRET=

# --- Payments (PayMe mobile money, /api/v1/pay/*) ----------------------
# Secret encrypting the PayMe credentials and session token stored in the
# database (AES-256-GCM). Required before configuring the gateway in the
# admin console. Never rotate it without re-entering the PayMe password.
PAYMENT_GATEWAY_ENCRYPTION_SECRET=
# Set to 1 to bypass PayMe entirely: checkouts auto-succeed after a few
# seconds. For local dev and end-to-end testing only.
PAYGATE_SANDBOX=
