# Copy to .env.local for local dev (Vite loads it automatically, git-ignored),
# or set as build-time environment variables on Vercel. Never commit a real .env*.
#
# These two only affect the built-in "AI Test" debug panel (harness/src/ai-test.jsx),
# which calls ai-server's /api/v1/generate directly. The in-game "Indice IA" and the
# "Synchro multi-appareils" panel are configured from inside the app itself (stored
# in the browser's localStorage), not via these build-time variables.

# Base URL of your deployed ai-server (Render) or http://localhost:8000 locally.
# Must be reachable from the BROWSER, not a Docker-internal hostname.
VITE_AI_SERVER_URL=http://localhost:8000

# Only needed if ai-server's AI_API_KEY is set. Note: any VITE_* value is bundled
# into the shipped JS and visible to anyone opening DevTools — casual deterrent only.
VITE_AI_API_TOKEN=
